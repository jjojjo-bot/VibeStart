# VibeStart 환경변수 템플릿
# 이 파일을 .env.local로 복사한 뒤 값을 채워주세요.
# cp .env.example .env.local

# ─── Supabase (사용자/프로젝트 DB) ───
NEXT_PUBLIC_AUTH_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_AUTH_SUPABASE_ANON_KEY=your-anon-key
AUTH_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── GitHub OAuth ───
# https://github.com/settings/developers 에서 OAuth App 등록
GITHUB_OAUTH_CLIENT_ID=your-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret

# ─── Supabase Management OAuth ───
# https://supabase.com/dashboard/org/<slug>/apps 에서 OAuth App 등록
SUPABASE_OAUTH_CLIENT_ID=your-supabase-oauth-client-id
SUPABASE_OAUTH_CLIENT_SECRET=your-supabase-oauth-client-secret

# ─── OAuth State 서명 ───
# 생성: openssl rand -hex 32
OAUTH_STATE_SECRET=your-random-32-char-hex-string
